# Bloomreach Engagement API
BLOOMREACH_BASE_URL=https://api.exponea.com
BLOOMREACH_PROJECT_TOKEN=your_project_token
BLOOMREACH_API_KEY_ID=your_api_key_id
BLOOMREACH_API_SECRET=your_api_secret

# Bloomreach Discovery API (optional, for future tools)
BLOOMREACH_DISCOVERY_AUTH_KEY=your_discovery_auth_key
BLOOMREACH_DISCOVERY_ACCOUNT_ID=your_account_id

# Transport: "stdio" (default, for Claude Desktop/Code) or "http" (for Cloud Run)
TRANSPORT=stdio

# HTTP transport settings (only used when TRANSPORT=http)
PORT=8080
BLOOMREACH_MCP_API_KEY=your_secret_api_key_for_http_mode
