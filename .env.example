# Bloomreach Engagement API
# Regional endpoint — defaults to https://api.exponea.com if not set
BLOOMREACH_BASE_URL=https://uk1-api.eng.bloomreach.com
BLOOMREACH_PROJECT_TOKEN=your_project_token
BLOOMREACH_API_KEY_ID=your_api_key_id
BLOOMREACH_API_SECRET=your_api_secret

# MCP server Bearer token (HTTP transport only)
# Any string — users put this in their claude_desktop_config.json Authorization header
BLOOMREACH_MCP_API_KEY=your_mcp_api_key

# Transport: "stdio" (default, for Claude Desktop/Code/Cursor) or "http" (for Cloud Run)
TRANSPORT=stdio

# HTTP transport settings (only used when TRANSPORT=http)
PORT=8080
